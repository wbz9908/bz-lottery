# =========================
# Common
# =========================
CONTAINER_TZ=Asia/Shanghai
SPRING_PROFILES_ACTIVE=prod

# =========================
# Public ports
# =========================
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443

# =========================
# Runtime images
# =========================
GATEWAY_IMAGE=lottery-platform/gateway:latest
USER_IMAGE=lottery-platform/user:latest
AWARD_IMAGE=lottery-platform/award:latest
LOTTERY_IMAGE=lottery-platform/lottery:latest
AI_IMAGE=lottery-platform/ai:latest

# =========================
# Database
# =========================
POSTGRES_IMAGE_TAG=17-alpine
POSTGRES_DB=lottery-platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
LOTTERY_DB_URL=jdbc:postgresql://postgres:5432/lottery-platform
LOTTERY_DB_USERNAME=postgres
LOTTERY_DB_PASSWORD=change-me

# =========================
# Redis
# =========================
REDIS_IMAGE_TAG=7-alpine
REDIS_HOST=redis
REDIS_PORT=6379

# =========================
# Optional remote config / registry
# Leave empty if not used in the first public rollout.
# =========================
NACOS_SERVER_ADDR=
NACOS_DISCOVERY_ENABLED=false
GATEWAY_DISCOVERY_ENABLED=false

# =========================
# AI analysis
# =========================
GLM_ENABLED=true
GLM_API_KEY=
GLM_MODEL=glm-5.1
